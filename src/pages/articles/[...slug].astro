---
import { getCollection, render } from "astro:content";
import ArticleLayout from "@layouts/ArticleLayout.astro";
import type { TocHeading } from "@components/TableOfContents.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles", ({ data }) =>
    import.meta.env.DEV ? true : !data.draft
  );

  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const allArticles = await getCollection("articles", ({ data }) =>
  import.meta.env.DEV ? true : !data.draft
);

// Auto-populate related: use frontmatter override, then fall back to 2 most recent
let relatedArticles = (article.data.related ?? [])
  .map(slug => allArticles.find(a => a.id === slug))
  .filter(Boolean)
  .map(a => ({
    title: a!.data.title,
    slug: a!.id,
    description: a!.data.description,
  }));

if (relatedArticles.length === 0) {
  relatedArticles = allArticles
    .filter(a => a.id !== article.id)
    .sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf())
    .slice(0, 2)
    .map(a => ({
      title: a.data.title,
      slug: a.id,
      description: a.data.description,
    }));
}

// Extract h2 headings from raw MDX body for table of contents
function extractHeadings(body: string): TocHeading[] {
  const headingRegex = /^## (.+)$/gm;
  const headings: TocHeading[] = [];
  let match: RegExpExecArray | null;
  while ((match = headingRegex.exec(body)) !== null) {
    const text = match[1]!;
    const slug = text
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, "-")
      .replace(/(^-|-$)/g, "");
    headings.push({ text, slug });
  }
  return headings;
}

function readingTimeMinutes(body: string): number {
  const words = body.trim().split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.ceil(words / 200));
}

const headings = extractHeadings(article.body ?? "");
const readTime = readingTimeMinutes(article.body ?? "");
const isDraft = article.data.draft === true;
---

<ArticleLayout
  title={article.data.title}
  description={article.data.description}
  date={article.data.date}
  tags={article.data.tags}
  related={relatedArticles}
  headings={headings}
  draft={isDraft}
  readingTimeMinutes={readTime}
>
  <Content />
</ArticleLayout>

---
import { getCollection } from "astro:content";
import Container from "@components/Container.astro";
import PageLayout from "@layouts/PageLayout.astro";
import Link from "@components/Link.astro";
import { dateRange } from "@lib/utils";
import { SITE, HOME, SOCIALS } from "@consts";

const allwork = (await getCollection("work"))
  .sort((a, b) => new Date(b.data.dateStart).valueOf() - new Date(a.data.dateStart).valueOf())
  .slice(0, SITE.NUM_WORKS_ON_HOMEPAGE);

const work = await Promise.all(
  allwork.map(async (item) => {
    const { Content } = await item.render();
    return { ...item, Content };
  })
);
---

<PageLayout title={HOME.TITLE} description={HOME.DESCRIPTION}>
  <Container>
    <div class="space-y-20">
      <section class="space-y-6">
        <div class="animate">
          <div class="w-12 h-1 bg-lime-400 mb-6"></div>
          <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-zinc-900 dark:text-white">
            Rafael Roman
          </h1>
        </div>
        <p class="animate text-lg text-zinc-600 dark:text-zinc-400 max-w-xl">
          CTO & Co-founder building the future of energy in Switzerland.
          <span class="text-zinc-400 dark:text-zinc-500">20+ years shipping software that matters.</span>
        </p>
        <div class="animate space-y-4 font-mono text-sm">
          <p>
            Co-founder & CTO of{" "}
            <Link href="https://upgrid.ch" external>Upgrid</Link>
            {" "}&mdash; a Swiss energy marketplace connecting local solar producers
            with consumers. Lower prices, 100% local renewable energy, zero hardware.
          </p>
          <p>
            From <Link href="https://n26.com" external>N26</Link> (Europe's largest neobank)
            and Personio to building 5+ international banks at GFT.
            Backend at heart &mdash; JVM, Kotlin, distributed systems, event-driven architecture.
          </p>
          <p>
            <span class="text-lime-600 dark:text-lime-400">Speaker:</span>{" "}
            Kafka Summit London, KotlinConf, WeAreDevelopers World Congress, TEDx.
          </p>
          <p class="text-zinc-400 dark:text-zinc-500">
            Based in Basel. From S&atilde;o Paulo. A decade in Barcelona.
          </p>
        </div>
      </section>

      {work.length > 0 && (
        <section class="animate space-y-6">
          <div class="flex flex-wrap gap-y-2 items-center justify-between">
            <h2 class="text-xl font-bold text-zinc-900 dark:text-white">
              Work
            </h2>
            <Link href="/work">
              See all
            </Link>
          </div>
          <ul class="flex flex-col space-y-4">
            {work.map(entry => (
              <li class="border-l-2 border-zinc-200 dark:border-zinc-800 pl-4 hover:border-lime-600/50 dark:hover:border-lime-400/50 transition-colors duration-300">
                <div class="text-xs font-mono text-zinc-400 dark:text-zinc-500">
                  {dateRange(entry.data.dateStart, entry.data.dateEnd)}
                </div>
                <div class="font-semibold text-zinc-900 dark:text-white">
                  {entry.data.company}
                </div>
                <div class="text-sm text-lime-600/70 dark:text-lime-400/70">
                  {entry.data.role}
                </div>
                <article>
                  <entry.Content />
                </article>
              </li>
            ))}
          </ul>
        </section>
      )}

      <section class="animate space-y-4">
        <h2 class="text-xl font-bold text-zinc-900 dark:text-white">
          Connect
        </h2>
        <p class="font-mono text-sm">
          Interested in distributed systems, fintech, energy tech, or engineering leadership? Find me on:
        </p>
        <ul class="flex flex-wrap gap-2">
          {SOCIALS.map((SOCIAL, i) => (
            <li class="flex gap-x-2 text-nowrap">
              <Link href={SOCIAL.HREF} external aria-label={`${SITE.NAME} on ${SOCIAL.NAME}`}>
                {SOCIAL.NAME}
              </Link>
              {i < SOCIALS.length - 1 && <span class="text-zinc-700">/</span>}
            </li>
          ))}
        </ul>
      </section>
    </div>
  </Container>
</PageLayout>

---
import Head from "@components/Head.astro";
import Header from "@components/Header.astro";
import Footer from "@components/Footer.astro";
import BackToPrev from "@components/BackToPrev.astro";
import RelatedLinks from "@components/RelatedLinks.astro";
import Link from "@components/Link.astro";
import { SITE } from "@consts";
import { breadcrumbSchema, eventSchema } from "@lib/seo";
import type { RelatedLink } from "@lib/related";

type Props = {
  pageTitle: string;
  description: string;
  event: string;
  talkTitle?: string;
  date: Date;
  location: string;
  externalLink?: string;
  kind?: "conference" | "meetup" | "community";
  relatedArticles?: RelatedLink[];
  relatedTalks?: RelatedLink[];
  relatedWork?: RelatedLink[];
};

const {
  pageTitle,
  description,
  event,
  talkTitle,
  date,
  location,
  externalLink,
  kind = "conference",
  relatedArticles = [],
  relatedTalks = [],
  relatedWork = [],
} = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const displayTitle = talkTitle ?? event;
const pageUrl = new URL(Astro.url.pathname, Astro.site).href;

const kindLabel =
  kind === "meetup" ? "Meetup" : kind === "community" ? "Community" : null;

const jsonLd = [
  eventSchema({
    name: talkTitle ? `${talkTitle} — ${event}` : event,
    description,
    url: pageUrl,
    startDate: date,
    location,
    externalUrl: externalLink,
  }),
  breadcrumbSchema([
    { name: SITE.NAME, url: new URL("/", Astro.site).href },
    { name: "Talks", url: new URL("/speaking/", Astro.site).href },
    { name: displayTitle, url: pageUrl },
  ]),
];
---

<!doctype html>
<html lang="en">
  <head>
    <Head title={pageTitle} description={description} jsonLd={jsonLd} />
  </head>
  <body>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-[max(1rem,env(safe-area-inset-top))] focus:left-4 focus:z-[100] focus:px-4 focus:py-2 focus:bg-lime-400 focus:text-zinc-900 focus:text-sm focus:font-mono focus:no-underline focus-ring">Skip to content</a>
    <Header />
    <main id="main">
      <div class="mx-auto max-w-2xl px-4 sm:px-5">
        <div class="space-y-12">
          <div>
            <BackToPrev href="/speaking">Back to talks</BackToPrev>
          </div>

          <div class="animate-hero space-y-8">
            <div class="signal-mark"></div>
            <div class="flex flex-wrap gap-x-3 gap-y-1 text-xs font-mono text-meta">
              <time datetime={date.toISOString()}>{formattedDate}</time>
              <span aria-hidden="true">·</span>
              <span>{location}</span>
              {kindLabel && (
                <>
                  <span aria-hidden="true">·</span>
                  <span class="text-lime-700 dark:text-lime-400">{kindLabel}</span>
                </>
              )}
            </div>
            <h1 class="text-3xl sm:text-4xl md:text-[3.25rem] font-display font-extrabold leading-[1.08] tracking-tight text-balance text-heading">
              {displayTitle}
            </h1>
            {talkTitle && (
              <p class="text-xl sm:text-2xl text-accent italic">{event}</p>
            )}
            {externalLink && (
              <p>
                <Link href={externalLink} external class="font-mono text-sm">
                  {talkTitle ? "→ Watch recording" : "→ View session"}
                </Link>
              </p>
            )}
          </div>

          <article class="prose dark:prose-invert max-w-none prose-p:text-zinc-600 dark:prose-p:text-zinc-400 prose-a:text-lime-600 dark:prose-a:text-lime-400">
            <slot />
          </article>

          <RelatedLinks heading="Related writing" items={relatedArticles} />
          <RelatedLinks heading="More talks" items={relatedTalks} />
          <RelatedLinks heading="Related work" items={relatedWork} />
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>

---
import { cn } from "@lib/utils";

type Props = {
  href: string;
  external?: boolean;
  underline?: boolean;
}

const { href, external, underline = true, ...rest } = Astro.props;
---

<a 
  href={href} 
  target={ external ? "_blank" : "_self" } 
  rel={ external ? "noopener noreferrer" : undefined }
  class={cn("inline-block text-current hover:text-lime-600 dark:hover:text-lime-400 transition-colors duration-300 ease-in-out", underline && "underline underline-offset-2 decoration-zinc-300 dark:decoration-zinc-700 hover:decoration-lime-600/50 dark:hover:decoration-lime-400/50")}
  {...rest}>
  <slot/>
</a>

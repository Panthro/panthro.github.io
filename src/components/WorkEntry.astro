---
type Props = {
  slug: string;
  dateRange: string;
  company: string;
  role: string;
  truncate?: boolean;
}

const { slug, dateRange, company, role, truncate = false } = Astro.props;
const href = `/work/${slug}/`;
---

<li class="pl-4 border-l border-transparent hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors duration-300">
  <div class="text-xs font-mono text-meta">
    {dateRange}
  </div>
  <div class="font-display font-bold text-lg">
    <a
      href={href}
      class="text-heading hover:text-lime-600 dark:hover:text-lime-400 focus-ring transition-colors duration-300"
    >
      {company}
    </a>
  </div>
  <div class="text-sm text-accent">
    {role}
  </div>
  <article class:list={[truncate && "line-clamp-3"]}>
    <slot />
  </article>
</li>

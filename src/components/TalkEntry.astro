---
type Props = {
  slug: string;
  event: string;
  title?: string;
  date: Date;
  location: string;
  link?: string;
  description?: string;
}

const { slug, event, title, date, location, link, description } = Astro.props;

const dateStr = date.toLocaleDateString("en-US", { month: "long", year: "numeric" });
const href = `/speaking/${slug}/`;
---

<li class="pl-4 border-l border-transparent hover:border-zinc-300 dark:hover:border-zinc-700 transition-colors duration-300">
  <div class="text-xs font-mono text-meta">{dateStr} · {location}</div>
  <h2 class="font-display font-bold text-lg">
    <a
      href={href}
      class="text-heading hover:text-lime-600 dark:hover:text-lime-400 focus-ring transition-colors duration-300"
    >
      {event}
    </a>
  </h2>
  {title && (
    <p class="text-sm text-accent italic">&ldquo;{title}&rdquo;</p>
  )}
  {description && (
    <p class="mt-1 text-sm text-meta">{description}</p>
  )}
  {link && (
    <a
      href={link}
      target="_blank"
      rel="noopener noreferrer"
      class="focus-ring touch-target-block inline-block mt-1 text-xs font-mono text-meta hover:text-lime-600 dark:hover:text-lime-400 transition-colors duration-300"
    >
      {title ? "→ Watch" : "→ View session"}
    </a>
  )}
</li>
